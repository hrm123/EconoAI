{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: VS Code Debug Build",
      //"type": "node-terminal",
      "type": "PowerShell", // PowerShell VS Code extension from Microsoft needs to be installed
      "request": "launch",
      // https://github.com/PowerShell/vscode-powershell/blob/main/examples/.vscode/launch.json
      // "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      // "command": "npm run build; npx serve out",
      "createTemporaryIntegratedConsole": true,
      "script": "${workspaceRoot}/debug.ps1",
      // "args": ["npm","run", "build", "&&", "npx", "serve", "out"],
       "cwd": "${workspaceRoot}",
      "serverReadyAction": {
        "pattern": "listening on (http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}